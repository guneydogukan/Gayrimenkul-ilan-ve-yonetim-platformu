@model emlaksitesi.Models.database.hakkimizda
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Edit</h2>
@using (Html.BeginForm("Edit", "About", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.id)


    <div class="card">
        <div class="card-header">
            <div class="card-title">Hakkımızda Düzenle</div>
            <div class="card-category"></div>
        </div>
        <div class="card-body">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Arkaplan Resmi :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="arkaplan_resim" class="form-control " accept="image/*" />

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextAreaFor(model => model.aciklama, new { @class = "form-control", @rows = "2", id= "editor" })

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama1 :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextAreaFor(model => model.aciklama1, new { @class = "form-control", @rows = "2" })

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama2 :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextAreaFor(model => model.aciklama2, new { @class = "form-control", @rows = "2" })

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama3 :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextAreaFor(model => model.aciklama3, new { @class = "form-control", @rows = "2" })

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Resim :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="resim" class="form-control " accept="image/*" />

                    </div>
                </div>


            </div>
        </div>
        <div class="card-footer">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12">

                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <button id="displayNotif" class="btn btn-success">Kaydet</button>
                        <a href="/About/Index" class="btn btn-primary">Geri Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
    CKEDITOR.replace('editor'); });
</script>



