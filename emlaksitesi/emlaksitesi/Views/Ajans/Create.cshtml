@model emlaksitesi.Models.database.ajans
@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using (Html.BeginForm("Create", "Ajans", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
   

    <div class="card">
        <div class="card-header">
            <div class="card-title">Ajanslara Ekle</div>
            <div class="card-category"></div>
        </div>
        <div class="card-body">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Resim :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="profil_resim" class="form-control " accept="image/*" />

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Ad Soyad :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextBoxFor(model => model.ad_soyad, new { @class = "form-control"})

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Görev :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        @Html.TextBoxFor(model => model.gorev, new { @class = "form-control" })

                    </div>
                </div>

                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextAreaFor(model => model.aciklama, new { @class = "form-control", @rows = "3" })
                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Twitter : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextBoxFor(model => model.twitter, new { @class = "form-control"})
                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Facebook : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextBoxFor(model => model.facebook, new { @class = "form-control" })
                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Instagram : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextBoxFor(model => model.instagram, new { @class = "form-control" })
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12">

                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <button id="displayNotif" class="btn btn-success">Kaydet</button>
                        <a href="/Ajans/Index" class="btn btn-primary">Geri Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }