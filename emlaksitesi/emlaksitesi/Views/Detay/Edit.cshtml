@model emlaksitesi.Models.database.detay
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using (Html.BeginForm("Edit", "Detay", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.id)

    <div class="card">
        <div class="card-header">
            <div class="card-title">Detayları Güncelle</div>
            <div class="card-category"></div>
        </div>
        <div class="card-body">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Resim :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="ev_resim1" class="form-control " accept="image/*" />
                    </div>

                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Resim :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="ev_resim2" class="form-control " accept="image/*" />
                    </div>


                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Resim :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="ev_resim3" class="form-control " accept="image/*" />
                    </div>

                </div>
             
               

                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Açıklama : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextAreaFor(model => model.aciklama, new { @class = "form-control", @rows = "3" })
                    </div>
                </div>
                
             
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Kişi Detay : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        @Html.DropDownListFor(model => model.kisidetay, (SelectList)ViewBag.KisiID, "Kişi Seç", new { @class = "form-control" })
                       
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12">

                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <button id="displayNotif" class="btn btn-success">Kaydet</button>
                        <a href="/Detay/Index" class="btn btn-primary">Geri Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
