@{
    if (Session["adminID"] == null)
    {
        Response.Redirect("/Yonetim/Login/");
    }
}

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <title>Admin Panel - Günay Emlak</title>
    <meta content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0, shrink-to-fit=no' name='viewport' />
    <link rel="stylesheet" href="~/Admin_Template/Admin_Template/assets/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i">
    <link rel="stylesheet" href="~/Admin_Template/Admin_Template/assets/css/ready.css">
    <link rel="stylesheet" href="~/Admin_Template/Admin_Template/assets/css/demo.css">

    <script src="~/Scripts/DataTables/jquery.dataTables.js"></script>
    <link href="~/Content/DataTables/css/jquery.dataTables.css" rel="stylesheet" />

    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>


    <!-- Custom CSS -->
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
        }

        .navbar {
            background-color: #343a40;
        }

            .navbar .navbar-brand {
                color: #fff;
                font-weight: bold;
            }

            .navbar .nav-link {
                color: #fff;
            }

        .sidebar {
            min-width: 250px;
            max-width: 250px;
            background-color: #212529;
            color: #fff;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
        }

            .sidebar ul {
                padding: 0;
                list-style: none;
            }

                .sidebar ul li {
                    margin: 0;
                }

                    .sidebar ul li a {
                        display: block;
                        padding: 10px 15px;
                        color: #adb5bd;
                        text-decoration: none;
                    }

                        .sidebar ul li a:hover, .sidebar ul li a.active {
                            background-color: #495057;
                            color: #fff;
                        }

        .sidebar-header {
            text-align: center;
            padding: 20px;
            background-color: #343a40;
            font-size: 1.25rem;
            font-weight: bold;
            color: #fff;
        }

        .main-content {
            margin-left: 250px;
            padding: 20px;
        }
    </style>

    @*user
        Bootstrap CSS*@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

    <link href="//cdn.datatables.net/2.0.1/css/dataTables.dataTables.min.css" rel="stylesheet" />
    <script src="//cdn.datatables.net/2.0.1/js/dataTables.min.js"></script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <script src="~/Content/ckeditor/ckeditor.js"></script>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>



</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Index">Günay Emlak</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="/User/Index"role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <strong>Admin</strong>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminMenu">
                        <li><a class="dropdown-item" href="/User/Index"><i class="fas fa-user"></i> Profilim</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Yonetim/logout"><i class="fas fa-sign-out-alt"></i> Çıkış</a></li>
                    </ul>
                </li>
            </ul>
        </div>

        </div>
    </nav>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/Home/Index" style="text-decoration: none; color: #fff;">Günay Emlak</a>
        </div>
        <ul>
            <li><a href="/Slider/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "Slider") ? "active" : "")"><i class="fas fa-home"></i> Emlak</a></li>
            <li><a href="/Detay/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "Detay") ? "active" : "")"><i class="fas fa-info-circle"></i> Detay</a></li>
            <li><a href="/Ajans/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "Ajans") ? "active" : "")"><i class="fas fa-building"></i> Ajans</a></li>
            <li><a href="/Contact/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "Contact") ? "active" : "")"><i class="fas fa-envelope"></i> Bize Ulaşın</a></li>
            <li><a href="/About/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "About") ? "active" : "")"><i class="fas fa-users"></i> Hakkımızda</a></li>
            <li><a href="/Messages/Index" class="@((ViewContext.RouteData.Values["controller"].ToString() == "Messages") ? "active" : "")"><i class="fas fa-comments"></i> Mesajlar</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdn.datatables.net/2.0.1/js/dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/js/all.min.js"></script>

</body>
<script src="~/Admin_Template/Admin_Template/assets/js/core/jquery.3.2.1.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/jquery-ui-1.12.1.custom/jquery-ui.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/core/popper.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/core/bootstrap.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/chartist/chartist.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/chartist/plugin/chartist-plugin-tooltip.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/bootstrap-toggle/bootstrap-toggle.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/jquery-mapael/jquery.mapael.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/jquery-mapael/maps/world_countries.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/chart-circle/circles.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/plugin/jquery-scrollbar/jquery.scrollbar.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/ready.min.js"></script>
<script src="~/Admin_Template/Admin_Template/assets/js/demo.js"></script>

</html>

