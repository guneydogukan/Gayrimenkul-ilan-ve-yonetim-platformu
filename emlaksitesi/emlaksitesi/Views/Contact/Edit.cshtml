@model emlaksitesi.Models.database.bize_ulasin
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using (Html.BeginForm("Edit", "Contact", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.id)

    <h4>İletişim Bilgilerini Güncelle</h4>
    <div class="card">
        <div class="card-header">
            <div class="card-title"></div>
            <div class="card-category"></div>
        </div>
        <div class="card-body">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Arkaplan Resmi :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <input type="file" name="arkaplan_resim" class="form-control " accept="image/*" />

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Konum Açıklama :</label>
                    </div>
                    <div class="col-lg-6 col-md-12 col-sm-12">
                        @Html.TextBoxFor(model => model.konum_aciklama, new { @class = "form-control" })

                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Hizmet Saatleri :</label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        @Html.TextBoxFor(model => model.hizmet_saatleri, new { @class = "form-control" })

                    </div>
                </div>

                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>E-mail : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextBoxFor(model => model.email, new { @class = "form-control" })
                    </div>
                </div>
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12 text-right">
                        <label>Telefon Numarası : </label>
                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">

                        @Html.TextBoxFor(model => model.telefon_numarasi, new { @class = "form-control" })
                    </div>
                </div>


            </div>
        </div>
        <div class="card-footer">
            <div class="form">
                <div class="form-group from-show-notify row">
                    <div class="col-lg-3 col-md-3 col-sm-12">

                    </div>
                    <div class="col-lg-6 col-md-9 col-sm-12">
                        <button id="displayNotif" class="btn btn-success">Kaydet</button>
                        <a href="/Contact/Index" class="btn btn-primary">Geri Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}




